---
interface RandomPlace {
	id: string;
	name: string;
	category: 'coffee' | 'food' | 'dessert' | 'icecream';
	visitedDate: string;
	city: string;
	country: string;
	lat: number;
	lng: number;
	mainImage: string;
	images: string[];
	imageLabels: string[][];
	menuItems: string[];
	notes?: string;
	googleMapsUrl: string;
}

interface Props {
	places: RandomPlace[];
}

const { places } = Astro.props;
---

<section
	id="random-globe-app"
	class="random-globe-app"
	data-places={JSON.stringify(places)}
>
	<div class="random-globe-layout">
		<div class="random-globe-stage" aria-label="Visited places globe">
			<div id="random-globe-fallback" class="random-globe-fallback" aria-live="polite">
				<p id="random-globe-status">Loading globe</p>
			</div>
			<div id="random-globe-canvas" class="random-globe-canvas"></div>
		</div>

		<aside id="random-place-detail" class="random-place-detail" aria-live="polite" hidden>
			<button id="random-place-close" class="random-place-close" type="button" aria-label="Close place details">
				<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 18 6M6 6l12 12"/>
				</svg>
			</button>
			<div id="random-place-content" class="random-place-content"></div>
		</aside>
	</div>

	<button id="random-global-back" class="random-global-back" type="button" aria-label="go back to global">
		<span class="random-global-back-tooltip">go back to global</span>
		<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 19-7-7 7-7"/>
		</svg>
	</button>
	<div id="random-utc-clock" class="random-utc-clock" aria-live="polite"></div>
</section>

<script>
	type RandomPlace = {
		id: string;
		name: string;
		category: 'coffee' | 'food' | 'dessert' | 'icecream';
		visitedDate: string;
		city: string;
		country: string;
		lat: number;
		lng: number;
		mainImage: string;
		images: string[];
		imageLabels: string[][];
		menuItems: string[];
		notes?: string;
		googleMapsUrl: string;
	};

	type PlaceMarker = RandomPlace & {
		kind: 'place';
		markerId: string;
		places: RandomPlace[];
		count: number;
		sourceLat: number;
		sourceLng: number;
		isExpanded?: boolean;
	};

	type ClusterMarker = {
		kind: 'cluster';
		id: string;
		markerId: string;
		lat: number;
		lng: number;
		city: string;
		country: string;
		category: RandomPlace['category'];
		mainImage: string;
		places: RandomPlace[];
		count: number;
		maxDistanceKm: number;
	};

	type GlobeMarker = PlaceMarker | ClusterMarker;

	const app = document.getElementById('random-globe-app');
	const globeNode = document.getElementById('random-globe-canvas');
	const stage = app?.querySelector('.random-globe-stage') as HTMLElement | null;
	const detail = document.getElementById('random-place-detail') as HTMLElement | null;
	const detailContent = document.getElementById('random-place-content');
	const closeButton = document.getElementById('random-place-close');
	const statusText = document.getElementById('random-globe-status');
	const utcClock = document.getElementById('random-utc-clock');
	const globalBackButton = document.getElementById('random-global-back');

	const categoryStyles = {
		coffee: {
			label: 'Coffee',
			color: 'var(--random-marker-coffee)',
			icon: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 8h10v5a4 4 0 0 1-4 4H9a4 4 0 0 1-4-4V8Z"/><path d="M15 10h1.5a2.5 2.5 0 0 1 0 5H15"/><path d="M6 20h10"/><path d="M8 4v2M12 4v2"/></svg>',
		},
		food: {
			label: 'Food',
			color: 'var(--random-marker-food)',
			icon: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 3v18"/><path d="M4 3v7a2 2 0 0 0 4 0V3"/><path d="M15 3v18"/><path d="M15 3c3 1 5 4 5 8 0 2.5-1.2 4-3 4h-2"/></svg>',
		},
		dessert: {
			label: 'Dessert',
			color: 'var(--random-marker-dessert)',
			icon: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 11h16"/><path d="M5 11l1.2 8h11.6L19 11"/><path d="M7 11c1-4 3.5-6 5-6s4 2 5 6"/><path d="M9 15h6"/></svg>',
		},
		icecream: {
			label: 'Ice cream',
			color: 'var(--random-marker-icecream)',
			icon: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 10a4 4 0 0 1 8 0"/><path d="M6 10h12"/><path d="M8 10l4 11 4-11"/><path d="M10.5 15h3"/></svg>',
		},
	};

	const chevronLeft = '<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m15 19-7-7 7-7"/></svg>';
	const chevronRight = '<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 5 7 7-7 7"/></svg>';
	const EARTH_RADIUS_KM = 6371;
	const GLOBAL_POINT_OF_VIEW = { lat: 22, lng: -35, altitude: 2.25 };
	const FREE_ZOOM_EXPAND_ALTITUDE = 0.95;
	const FREE_ZOOM_TARGET_ALTITUDE = 0.64;
	const FREE_ZOOM_MIN_ALTITUDE = 0.28;
	const FREE_ZOOM_GLOBAL_MIN_ALTITUDE = 0.78;
	const FREE_ZOOM_COLLAPSE_ALTITUDE = 1.55;

	const escapeHtml = (value: unknown) =>
		String(value ?? '').replace(/[&<>"']/g, (char) => ({
			'&': '&amp;',
			'<': '&lt;',
			'>': '&gt;',
			'"': '&quot;',
			"'": '&#39;',
		})[char] || char);

	const escapeAttribute = escapeHtml;

	function normalizeImageLabels(value: unknown) {
		if (!value) return [];
		return (Array.isArray(value) ? value : [value])
			.map((label) => String(label).trim())
			.filter(Boolean);
	}

	function normalizeMenuMatch(value: string) {
		return value
			.toLowerCase()
			.replace(/\([^)]*\)/g, '')
			.replace(/[^a-z0-9]+/g, ' ')
			.trim();
	}

	function menuItemMatchesLabels(item: string, labels: string[]) {
		const itemMatch = normalizeMenuMatch(item);
		return labels.some((label) => itemMatch === normalizeMenuMatch(label));
	}

	const dayNightShader = {
		vertexShader: `
			varying vec3 vNormal;
			void main() {
				vNormal = normalize(normalMatrix * normal);
				gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
			}
		`,
		fragmentShader: `
			#define PI 3.141592653589793
			uniform vec3 baseColor;
			uniform vec3 nightColor;
			uniform vec2 sunPosition;
			uniform vec2 globeRotation;
			uniform float shadowStrength;
			varying vec3 vNormal;

			float toRad(in float angle) {
				return angle * PI / 180.0;
			}

			vec3 polar2Cartesian(in vec2 coordinates) {
				float theta = toRad(90.0 - coordinates.x);
				float phi = toRad(90.0 - coordinates.y);
				return vec3(
					sin(phi) * cos(theta),
					cos(phi),
					sin(phi) * sin(theta)
				);
			}

			void main() {
				float invLon = toRad(globeRotation.x);
				float invLat = -toRad(globeRotation.y);
				mat3 rotX = mat3(
					1, 0, 0,
					0, cos(invLat), -sin(invLat),
					0, sin(invLat), cos(invLat)
				);
				mat3 rotY = mat3(
					cos(invLon), 0, sin(invLon),
					0, 1, 0,
					-sin(invLon), 0, cos(invLon)
				);
				vec3 rotatedSunDirection = rotX * rotY * polar2Cartesian(sunPosition);
				float intensity = dot(normalize(vNormal), normalize(rotatedSunDirection));
				float night = 1.0 - smoothstep(-0.14, 0.18, intensity);
				vec3 shaded = mix(baseColor, nightColor, night * shadowStrength);
				gl_FragColor = vec4(shaded, 1.0);
			}
		`,
	};

	function setGlobeStatus(message: string) {
		if (statusText) statusText.textContent = message;
	}

	function supportsWebGL() {
		const testCanvas = document.createElement('canvas');
		return Boolean(testCanvas.getContext('webgl') || testCanvas.getContext('experimental-webgl'));
	}

	function getCssVariable(name: string, fallback: string) {
		if (!app) return fallback;
		const value = getComputedStyle(app).getPropertyValue(name).trim();
		return value || fallback;
	}

	function updateUtcClock(time = new Date()) {
		if (!utcClock) return;
		const stamp = time.toISOString().replace('T', ' ').slice(0, 19);
		utcClock.textContent = `${stamp} UTC`;
	}

	function toRadians(value: number) {
		return value * Math.PI / 180;
	}

	function distanceKm(a: { lat: number; lng: number }, b: { lat: number; lng: number }) {
		const dLat = toRadians(b.lat - a.lat);
		const dLng = toRadians(b.lng - a.lng);
		const lat1 = toRadians(a.lat);
		const lat2 = toRadians(b.lat);
		const h =
			Math.sin(dLat / 2) ** 2 +
			Math.cos(lat1) * Math.cos(lat2) * Math.sin(dLng / 2) ** 2;
		return 2 * EARTH_RADIUS_KM * Math.asin(Math.min(1, Math.sqrt(h)));
	}

	function clusterDistanceForAltitude(altitude = 2.25) {
		if (altitude > 1.85) return 35;
		if (altitude > 1.25) return 12;
		if (altitude > 0.92) return 4;
		if (altitude > 0.68) return 1.1;
		return 0.12;
	}

	function clusterFocusAltitude(cluster: ClusterMarker) {
		if (cluster.maxDistanceKm > 18) return 0.18;
		if (cluster.maxDistanceKm > 6) return 0.1;
		if (cluster.maxDistanceKm > 2) return 0.032;
		return 0.024;
	}

	function markerSignature(markers: GlobeMarker[]) {
		return markers
			.map((marker) => `${marker.kind}:${marker.markerId}:${marker.count}:${marker.lat.toFixed(5)}:${marker.lng.toFixed(5)}`)
			.join('|');
	}

	function createPlaceMarker(
		place: RandomPlace,
		position: { lat: number; lng: number } = place,
		isExpanded = false,
	): PlaceMarker {
		return {
			...place,
			lat: position.lat,
			lng: position.lng,
			kind: 'place',
			markerId: `place:${place.id}`,
			places: [place],
			count: 1,
			sourceLat: place.lat,
			sourceLng: place.lng,
			isExpanded,
		};
	}

	function dominantCategory(places: RandomPlace[]) {
		const counts = places.reduce<Record<RandomPlace['category'], number>>((acc, place) => {
			acc[place.category] = (acc[place.category] || 0) + 1;
			return acc;
		}, { coffee: 0, food: 0, dessert: 0, icecream: 0 });

		return (Object.entries(counts).sort((a, b) => b[1] - a[1])[0]?.[0] || 'coffee') as RandomPlace['category'];
	}

	function buildExpandedMarkers(places: RandomPlace[], expandedPlaceIds: Set<string>) {
		const sortedPlaces = [...places].sort((a, b) =>
			[a.country, a.city, a.name].join('|').localeCompare([b.country, b.city, b.name].join('|'))
		);

		return sortedPlaces.map((place) => {
			if (!expandedPlaceIds.has(place.id)) return createPlaceMarker(place);
			return createPlaceMarker(place, place, true);
		});
	}

	function getPlaceFocusPosition(place: RandomPlace) {
		return {
			lat: place.lat,
			lng: place.lng,
		};
	}

	function getPlaceSource(place: RandomPlace) {
		if ('sourceLat' in place && 'sourceLng' in place) {
			return {
				...place,
				lat: Number((place as PlaceMarker).sourceLat),
				lng: Number((place as PlaceMarker).sourceLng),
			};
		}

		return place;
	}

	function buildMarkerClusters(places: RandomPlace[], altitude: number): GlobeMarker[] {
		const thresholdKm = clusterDistanceForAltitude(altitude);
		const buckets: Array<{ lat: number; lng: number; places: RandomPlace[] }> = [];
		const sortedPlaces = [...places].sort((a, b) =>
			[a.country, a.city, a.name].join('|').localeCompare([b.country, b.city, b.name].join('|'))
		);

		sortedPlaces.forEach((place) => {
			let nearestBucket: typeof buckets[number] | null = null;
			let nearestDistance = Infinity;

			buckets.forEach((bucket) => {
				const distance = distanceKm(place, bucket);
				if (distance <= thresholdKm && distance < nearestDistance) {
					nearestBucket = bucket;
					nearestDistance = distance;
				}
			});

			if (!nearestBucket) {
				buckets.push({ lat: place.lat, lng: place.lng, places: [place] });
				return;
			}

			nearestBucket.places.push(place);
			nearestBucket.lat = nearestBucket.places.reduce((sum, item) => sum + item.lat, 0) / nearestBucket.places.length;
			nearestBucket.lng = nearestBucket.places.reduce((sum, item) => sum + item.lng, 0) / nearestBucket.places.length;
		});

		return buckets.map((bucket) => {
			if (bucket.places.length === 1) return createPlaceMarker(bucket.places[0]);

			const sortedIds = bucket.places.map((place) => place.id).sort();
			const maxDistanceKm = bucket.places.reduce((max, place) => Math.max(max, distanceKm(place, bucket)), 0);
			const firstPlace = bucket.places[0];

			return {
				kind: 'cluster',
				id: sortedIds.join('+'),
				markerId: `cluster:${sortedIds.join('+')}`,
				lat: bucket.lat,
				lng: bucket.lng,
				city: firstPlace.city,
				country: firstPlace.country,
				category: dominantCategory(bucket.places),
				mainImage: firstPlace.mainImage,
				places: bucket.places,
				count: bucket.places.length,
				maxDistanceKm,
			};
		});
	}

	async function initRandomGlobe() {
		if (!(app && globeNode && stage && detail && detailContent)) return;

		if (!supportsWebGL()) {
			app.classList.add('is-fallback');
			setGlobeStatus('enable chrome graphics acceleration');
			return;
		}

		const places = JSON.parse(app.dataset.places || '[]') as RandomPlace[];
		let selectedPlace: RandomPlace | null = null;
		let selectedImageIndex = 0;
		let controls: any = null;
		let currentMarkerSignature = '';
		let expandedPlaceIds = new Set<string>();
		let isClusterZooming = false;
		let isFreeZooming = false;

		try {
			const [
				{ default: Globe },
				three,
				topojson,
				landAtlas,
				solar,
			] = await Promise.all([
				import('globe.gl'),
				import('three'),
				import('topojson-client'),
				import('world-atlas/land-110m.json'),
				import('solar-calculator'),
			]);

			const { Color, DoubleSide, ShaderMaterial, Vector2 } = three;
			const landTopo = (landAtlas as any).default || landAtlas;
			const landFeatures = (topojson as any).feature(landTopo, landTopo.objects.land).features;
			const globeFillColor = getCssVariable('--random-globe-fill', document.documentElement.classList.contains('dark') ? '#a7b3c4' : '#e5e9f0');
			const continentColor = getCssVariable('--random-continent', document.documentElement.classList.contains('dark') ? '#88c0d0' : '#5e81ac');
			const nightColor = getCssVariable('--random-night', document.documentElement.classList.contains('dark') ? '#2e3440' : '#4c566a');
			const polygonStrokeColor = () => getCssVariable('--random-continent-stroke', document.documentElement.classList.contains('dark') ? 'rgba(136, 192, 208, 0.36)' : 'rgba(94, 129, 172, 0.34)');

			const createDayNightMaterial = (baseColor: string, strength: number) => new ShaderMaterial({
				uniforms: {
					baseColor: { value: new Color(baseColor) },
					nightColor: { value: new Color(nightColor) },
					sunPosition: { value: new Vector2() },
					globeRotation: { value: new Vector2() },
					shadowStrength: { value: strength },
				},
				vertexShader: dayNightShader.vertexShader,
				fragmentShader: dayNightShader.fragmentShader,
				side: DoubleSide,
			});

			const globeMaterial = createDayNightMaterial(globeFillColor, 0.68);
			const landMaterial = createDayNightMaterial(continentColor, 0.58);

			const sunPosAt = (time: Date) => {
				const day = new Date(+time).setUTCHours(0, 0, 0, 0);
				const t = (solar as any).century(time);
				const longitude = (day - +time) / 864e5 * 360 - 180;
				return [longitude - (solar as any).equationOfTime(t) / 4, (solar as any).declination(t)];
			};

			const updateSun = () => {
				const now = new Date();
				const [lng, lat] = sunPosAt(now);
				globeMaterial.uniforms.sunPosition.value.set(lng, lat);
				landMaterial.uniforms.sunPosition.value.set(lng, lat);
				const pov = world.pointOfView();
				globeMaterial.uniforms.globeRotation.value.set(pov.lng, pov.lat);
				landMaterial.uniforms.globeRotation.value.set(pov.lng, pov.lat);
				updateUtcClock(now);
			};

		const world = Globe()(globeNode)
			.backgroundColor('rgba(0,0,0,0)')
			.showAtmosphere(false)
			.globeMaterial(globeMaterial)
			.polygonsData(landFeatures)
			.polygonCapMaterial(landMaterial)
			.polygonSideColor(() => 'rgba(0,0,0,0)')
			.polygonStrokeColor(polygonStrokeColor)
			.polygonAltitude(0.003)
			.htmlElementsData([])
			.htmlLat('lat')
			.htmlLng('lng')
			.htmlAltitude(0.03)
			.htmlTransitionDuration(250)
			.htmlElement(createMarker)
			.htmlElementVisibilityModifier((el, isVisible) => {
				el.style.opacity = isVisible ? '1' : '0';
				el.style.pointerEvents = isVisible ? 'auto' : 'none';
			})
			.onZoom(({ lng, lat }) => {
				globeMaterial.uniforms.globeRotation.value.set(lng, lat);
				landMaterial.uniforms.globeRotation.value.set(lng, lat);
				const pov = world.pointOfView();

				if (!app.classList.contains('is-zoomed') && pov.altitude <= FREE_ZOOM_EXPAND_ALTITUDE) {
					setZoomedLayout(true);
					controls.autoRotate = false;

					if (!isFreeZooming && selectedPlace && pov.altitude > FREE_ZOOM_TARGET_ALTITUDE) {
						isFreeZooming = true;
						world.pointOfView({ ...pov, altitude: FREE_ZOOM_TARGET_ALTITUDE }, 520);
						window.setTimeout(() => {
							isFreeZooming = false;
						}, 560);
					}
				}

				if (
					app.classList.contains('is-zoomed') &&
					expandedPlaceIds.size === 0 &&
					pov.altitude < (selectedPlace ? FREE_ZOOM_MIN_ALTITUDE : FREE_ZOOM_GLOBAL_MIN_ALTITUDE) &&
					!isFreeZooming
				) {
					isFreeZooming = true;
					world.pointOfView({
						...pov,
						altitude: selectedPlace ? FREE_ZOOM_MIN_ALTITUDE : FREE_ZOOM_GLOBAL_MIN_ALTITUDE,
					}, 160);
					window.setTimeout(() => {
						isFreeZooming = false;
					}, 200);
				}

				if (expandedPlaceIds.size > 0 && !isClusterZooming && pov.altitude > 1.45) {
					expandedPlaceIds = new Set();
					setZoomedLayout(false);
				} else if (
					app.classList.contains('is-zoomed') &&
					expandedPlaceIds.size === 0 &&
					!selectedPlace &&
					!isFreeZooming &&
					pov.altitude > FREE_ZOOM_COLLAPSE_ALTITUDE
				) {
					setZoomedLayout(false);
					controls.autoRotate = true;
				}

				updateMarkersForView();
			})
			.pointOfView(GLOBAL_POINT_OF_VIEW);

		controls = world.controls();
		controls.autoRotate = true;
		controls.autoRotateSpeed = 0.55;
		controls.enableZoom = true;
		controls.zoomSpeed = 0.78;
		controls.enableDamping = true;
		controls.dampingFactor = 0.07;
		controls.minDistance = 8;
		controls.maxDistance = 680;

		world.renderer().setPixelRatio(Math.min(2, window.devicePixelRatio || 1));
		const utcTimer = window.setInterval(updateSun, 1000);
		const applyThemeColors = () => {
			globeMaterial.uniforms.baseColor.value.set(getCssVariable('--random-globe-fill', document.documentElement.classList.contains('dark') ? '#a7b3c4' : '#e5e9f0'));
			landMaterial.uniforms.baseColor.value.set(getCssVariable('--random-continent', document.documentElement.classList.contains('dark') ? '#88c0d0' : '#5e81ac'));
			globeMaterial.uniforms.nightColor.value.set(getCssVariable('--random-night', document.documentElement.classList.contains('dark') ? '#2e3440' : '#4c566a'));
			landMaterial.uniforms.nightColor.value.set(getCssVariable('--random-night', document.documentElement.classList.contains('dark') ? '#2e3440' : '#4c566a'));
			world.polygonStrokeColor(polygonStrokeColor);
		};
		const themeObserver = new MutationObserver(applyThemeColors);
		themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class', 'data-theme'] });

		function resizeGlobe() {
			const rect = stage.getBoundingClientRect();
			const fallback = Math.min(window.innerWidth, window.innerHeight - 96);

			if (app.classList.contains('is-zoomed')) {
				const width = Math.max(320, Math.floor(rect.width || window.innerWidth));
				const height = Math.max(320, Math.floor(rect.height || window.innerHeight));
				globeNode.style.width = `${width}px`;
				globeNode.style.height = `${height}px`;
				world.width(width).height(height);
				return;
			}

			const size = Math.max(300, Math.floor(Math.min(rect.width, rect.height || fallback)));
			globeNode.style.width = `${size}px`;
			globeNode.style.height = `${size}px`;
			world.width(size).height(size);
		}

		function setZoomedLayout(isZoomed: boolean) {
			if (app.classList.contains('is-zoomed') === isZoomed) return;
			app.classList.toggle('is-zoomed', isZoomed);
			resizeGlobe();
			updateMarkersForView(true);
		}

		function updateMarkersForView(force = false) {
			const markers = expandedPlaceIds.size > 0
				? buildExpandedMarkers(places, expandedPlaceIds)
				: buildMarkerClusters(places, world.pointOfView().altitude);
			const nextSignature = markerSignature(markers);
			if (!force && nextSignature === currentMarkerSignature) return;

			currentMarkerSignature = nextSignature;
			world.htmlElementsData(markers);
		}

		function createMarker(markerData: GlobeMarker) {
			const marker = document.createElement('button');
			const style = categoryStyles[markerData.category] || categoryStyles.coffee;
			marker.type = 'button';
			marker.className = markerData.kind === 'cluster'
				? 'globe-marker globe-marker-cluster'
				: `globe-marker${markerData.isExpanded ? ' globe-marker-expanded' : ''}`;
			marker.style.setProperty('--marker-color', style.color);
			marker.setAttribute('aria-label', markerData.kind === 'cluster'
				? `${markerData.count} places near ${markerData.city}, ${markerData.country}`
				: markerData.name);

			if (markerData.kind === 'cluster') {
				const placePreview = markerData.places
					.slice(0, 5)
					.map((place) => `<span>${escapeHtml(place.name)}</span>`)
					.join('');
				const remainingCount = markerData.count > 5
					? `<span>+${markerData.count - 5} more</span>`
					: '';

				marker.innerHTML = `
					<span class="globe-marker-preview globe-cluster-preview">
						<span class="globe-cluster-preview-title">${markerData.count} nearby places</span>
						<span class="globe-cluster-preview-list">${placePreview}${remainingCount}</span>
					</span>
					<span class="globe-marker-cluster-bubble">
						<span class="globe-cluster-count">${markerData.count}</span>
					</span>
				`;
			} else {
				marker.innerHTML = `
					<span class="globe-marker-preview">
						<img src="${escapeAttribute(markerData.mainImage)}" alt="${escapeAttribute(markerData.name)}" loading="lazy" />
						<span>${escapeHtml(markerData.name)}</span>
					</span>
					<span class="globe-marker-pin">
						<svg class="globe-marker-shape" viewBox="-4 0 36 36" aria-hidden="true">
							<path fill="currentColor" d="M14 0c7.73 0 14 5.64 14 12.6C28 23.96 14 36 14 36S0 24.06 0 12.6C0 5.64 6.27 0 14 0Z"/>
						</svg>
						<span class="globe-marker-logo">${style.icon}</span>
					</span>
				`;
			}

			marker.addEventListener('click', (event) => {
				event.stopPropagation();
				if (markerData.kind === 'cluster') {
					zoomToCluster(markerData);
				} else {
					selectPlace(markerData);
				}
			});
			marker.addEventListener('mouseenter', () => {
				if (controls) controls.autoRotate = false;
			});
			marker.addEventListener('mouseleave', () => {
				if (controls && !selectedPlace && expandedPlaceIds.size === 0) controls.autoRotate = true;
			});
			marker.addEventListener('focus', () => {
				if (controls) controls.autoRotate = false;
			});
			marker.addEventListener('blur', () => {
				if (controls && !selectedPlace && expandedPlaceIds.size === 0) controls.autoRotate = true;
			});
			return marker;
		}

		function zoomToCluster(cluster: ClusterMarker) {
			selectedPlace = null;
			expandedPlaceIds = new Set(cluster.places.map((place) => place.id));
			isClusterZooming = true;
			setZoomedLayout(true);
			app.classList.remove('has-selection');
			detail.hidden = true;
			controls.autoRotate = false;
			resizeGlobe();
			updateMarkersForView(true);
			world.pointOfView({
				lat: cluster.lat,
				lng: cluster.lng,
				altitude: Math.min(world.pointOfView().altitude, clusterFocusAltitude(cluster)),
			}, 1100);
			window.setTimeout(() => {
				isClusterZooming = false;
				updateMarkersForView(true);
			}, 1120);
		}

		function selectPlace(place: RandomPlace) {
			selectedPlace = getPlaceSource(place);
			selectedImageIndex = 0;
			app.classList.add('has-selection');
			detail.hidden = false;
			controls.autoRotate = false;
			renderDetail();
			window.setTimeout(resizeGlobe, 280);
			world.pointOfView({
				...getPlaceFocusPosition(place),
				altitude: expandedPlaceIds.size > 0
					? world.pointOfView().altitude
					: Math.min(world.pointOfView().altitude, 1.1),
			}, 850);
		}

		function closeDetail() {
			selectedPlace = null;
			app.classList.remove('has-selection');
			detail.hidden = true;
			controls.autoRotate = expandedPlaceIds.size === 0;
			window.setTimeout(resizeGlobe, 280);
		}

		function goBackToGlobal() {
			selectedPlace = null;
			expandedPlaceIds = new Set();
			isFreeZooming = false;
			app.classList.remove('has-selection');
			detail.hidden = true;
			controls.autoRotate = true;
			setZoomedLayout(false);
			updateMarkersForView(true);
			world.pointOfView(GLOBAL_POINT_OF_VIEW, 1100);
		}

		function forwardWheelToRenderer(event: WheelEvent) {
			const rendererCanvas = world.renderer().domElement;
			if (event.target === rendererCanvas) return;

			event.preventDefault();
			rendererCanvas.dispatchEvent(new WheelEvent('wheel', {
				altKey: event.altKey,
				bubbles: true,
				cancelable: true,
				clientX: event.clientX,
				clientY: event.clientY,
				ctrlKey: event.ctrlKey,
				deltaMode: event.deltaMode,
				deltaX: event.deltaX,
				deltaY: event.deltaY,
				deltaZ: event.deltaZ,
				metaKey: event.metaKey,
				shiftKey: event.shiftKey,
			}));
		}

		function renderDetail() {
			if (!selectedPlace) return;
			const place = selectedPlace;
			const style = categoryStyles[place.category] || categoryStyles.coffee;
			const images = place.images.length > 0 ? place.images : [place.mainImage];
			const activeImage = images[selectedImageIndex] || place.mainImage;
			const activeImageLabels = normalizeImageLabels(place.imageLabels?.[selectedImageIndex]);
			const location = [place.city, place.country].filter(Boolean).join(', ');
			const date = new Date(`${place.visitedDate}T00:00:00`);
			const dateLabel = Number.isNaN(date.getTime())
				? place.visitedDate
				: date.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' });

			detailContent.innerHTML = `
				<div class="place-photo-wrap">
					<img class="place-photo" src="${escapeAttribute(activeImage)}" alt="${escapeAttribute(place.name)}" />
					${images.length > 1 ? `
						<button class="place-carousel-button is-prev" type="button" aria-label="Previous image">${chevronLeft}</button>
						<button class="place-carousel-button is-next" type="button" aria-label="Next image">${chevronRight}</button>
						<div class="place-carousel-count">${selectedImageIndex + 1} / ${images.length}</div>
					` : ''}
				</div>

				<div class="place-kicker" style="--place-accent: ${style.color}">
					<span>${style.icon}</span>
					${escapeHtml(style.label)}
				</div>

				<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 dark:text-white">${escapeHtml(place.name)}</h1>
				<p class="place-meta">${escapeHtml(dateLabel)} · ${escapeHtml(location)}</p>

				${place.menuItems.length > 0 ? `
					<div class="place-section">
						<h2>Menu</h2>
						<ul>
							${place.menuItems.map((item) => `
								<li class="${menuItemMatchesLabels(item, activeImageLabels) ? 'is-active' : ''}">
									${escapeHtml(item)}
								</li>
							`).join('')}
						</ul>
					</div>
				` : ''}

				${place.notes ? `
					<div class="place-section">
						<h2>Notes</h2>
						<p>${escapeHtml(place.notes)}</p>
					</div>
				` : ''}

				<a class="place-map-link" href="${escapeAttribute(place.googleMapsUrl)}" target="_blank" rel="noreferrer">
					<span>Open in Google Maps</span>
					<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 6H18m0 0v4.5M18 6 10.5 13.5M6 8.5v9.5h9.5"/>
					</svg>
				</a>
			`;

			detailContent.querySelector('.is-prev')?.addEventListener('click', () => {
				selectedImageIndex = (selectedImageIndex - 1 + images.length) % images.length;
				renderDetail();
			});

			detailContent.querySelector('.is-next')?.addEventListener('click', () => {
				selectedImageIndex = (selectedImageIndex + 1) % images.length;
				renderDetail();
			});

		}

		closeButton?.addEventListener('click', closeDetail);
		globalBackButton?.addEventListener('click', goBackToGlobal);
		globeNode.addEventListener('wheel', forwardWheelToRenderer, { passive: false });
		window.addEventListener('resize', resizeGlobe);
		window.addEventListener('beforeunload', () => {
			window.clearInterval(utcTimer);
			themeObserver.disconnect();
			globeNode.removeEventListener('wheel', forwardWheelToRenderer);
		});

		if ('ResizeObserver' in window) {
			new ResizeObserver(resizeGlobe).observe(stage);
		}

			requestAnimationFrame(() => {
			resizeGlobe();
			updateSun();
			updateMarkersForView(true);
			window.setTimeout(() => app.classList.add('is-loaded'), 350);
		});
		} catch (error) {
			console.error('Random globe failed to initialize', error);
			app.classList.add('is-fallback');
			setGlobeStatus('enable chrome graphics acceleration');
		}
	}

	initRandomGlobe();
</script>

