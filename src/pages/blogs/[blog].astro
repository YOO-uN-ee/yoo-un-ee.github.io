---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
    // Astro.glob is the safest way to pass Markdown components via props
    const posts = await Astro.glob('../../data/blog-contents/*/description.md');
    
    return posts.map(post => {
        const parts = post.file.split('/');
        const folder = parts[parts.length - 2];
        return {
            params: { blog: folder },
            props: { post } 
        };
    });
}

const { blog } = Astro.params;
const { post } = Astro.props;

// Safely extract the component and frontmatter
const Content = post.Content;
const frontmatter = post.frontmatter || {};
const title = frontmatter.title || blog;
const summary = frontmatter.summary || '';
const date = frontmatter.date || '';
const tags = frontmatter.tags || [];
const bibtex = frontmatter.bibtex || null;

// Updated to look inside the specific 'imgs' folder next to description.md
const allImages = import.meta.glob('../../data/blog-contents/*/imgs/*.{png,jpg,jpeg,webp,gif}', { eager: true });
const blogImages = Object.keys(allImages)
    .filter(path => path.includes(`/${blog}/imgs/`))
    .map(path => (allImages[path] as any).default.src);

const translations = {
    backToProjects: { en: '← Back to Blogs', es: '← Volver a los Blogs' },
    links: { en: 'BibTex', es: 'Enlaces' }
};
---

<Layout title={`${title} | Jiyoon Pyo`}>
	<Header />
	
	<main class="min-h-screen px-4 sm:px-6 md:px-6">
        <article class="max-w-3xl mx-auto pt-24 sm:pt-32 md:pt-48 pb-16 sm:pb-24">
			<a href="/blogs" class="text-sm font-medium text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors mb-12 inline-block">
				{translations.backToProjects.en}
			</a>

			<header class="mb-8">
				<h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">
					{title}
				</h1>
                
                {date && (
                    <div class="flex gap-3 mb-8">
                        <span class="px-4 py-1.5 rounded-full border border-gray-300 dark:border-gray-700 text-sm font-medium text-gray-600 dark:text-gray-400">
                            {date}
                        </span>
                    </div>
                )}

                {summary && (
                    <div class="mt-3 sm:mt-4 text-sm sm:text-lg text-gray-600 dark:text-gray-400">
                        [{summary}]
                    </div>
                )}
			</header>

            <hr class="border-t-2 border-gray-800 dark:border-gray-200 my-12 w-full" />

            <div class="space-y-16">
				<section class="prose dark:prose-invert max-w-none prose-img:rounded-xl prose-img:border prose-img:border-gray-200 dark:prose-img:border-gray-800">
                    <Content />
                </section>

				{bibtex && (
					<section>
						<h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">
							{translations.links.en}
						</h2>
						<div class="bg-gray-50 dark:bg-gray-900 p-4 rounded-lg overflow-x-auto">
							<pre class="text-sm text-gray-700 dark:text-gray-300"><code>{bibtex}</code></pre>
						</div>
					</section>
				)}

				<!-- {blogImages.length > 0 && (
					<section>
						<div class="grid grid-cols-1 gap-8">
							{blogImages.map((src) => (
								<div class="relative rounded-xl overflow-hidden border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/50">
									<img src={src} alt={`Blog visual content`} class="w-full h-auto" loading="lazy" />
								</div>
							))}
						</div>
					</section>
				)} -->

                {tags.length > 0 && (
                    <section class="pt-8 border-t border-gray-200 dark:border-gray-800">
                        <div class="flex flex-wrap gap-3 items-center">
                            <span class="text-sm font-bold text-gray-400 uppercase tracking-wider mr-2">Tags</span>
                            {tags.map((tech: string) => (
                                <span class="px-4 py-1.5 text-sm font-medium rounded-full border border-gray-300 dark:border-gray-700 text-gray-600 dark:text-gray-400 bg-white dark:bg-gray-900 shadow-sm cursor-default">
                                    {tech}
                                </span>
                            ))}
                        </div>
                    </section>
                )}
			</div>
		</article>
	</main>
	<Footer />
</Layout>

<style>
	@reference "../../styles/global.css";
</style>